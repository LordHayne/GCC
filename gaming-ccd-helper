# gaming-ccd-helper — root helper for Gaming Command Center
# Called via pkexec from the GUI.
#
# Usage:
#   gaming-ccd-helper park <cpu-list>     e.g. park 6,7,8,9,10,11,18,19,20,21,22,23
#   gaming-ccd-helper unpark <cpu-list>
#   gaming-ccd-helper unpark-all
#   gaming-ccd-helper governor | audio | sata
#   gaming-ccd-helper set-governor <name>   (benchmark uses this, then restores)
#
# Everything here is a runtime sysfs change: it is undone by a reboot, so the
# polkit action runs without a password. Persistent /etc edits are deliberately
# NOT in this script — they live in gaming-cc-etc-helper behind an action that
# does require authentication.
#
# The CPU list comes from the GUI, which derives it from the sysfs topology
# (see topology.py). This script hardcodes no CPU layout — but it does not trust
# the caller either: every CPU number is validated before anything is written,
# CPU0 is never taken offline, and a park that would leave fewer than 2 CPUs
# running is refused.

set -u

SYS_CPU=/sys/devices/system/cpu

die() { echo "ERR: $1" >&2; exit 1; }

# Validate a comma-separated CPU list and print it back, one CPU per line.
parse_cpus() {
    local raw="$1" cpu out=()
    [[ "$raw" =~ ^[0-9]+(,[0-9]+)*$ ]] || die "invalid cpu list: '$raw'"
    IFS=',' read -ra items <<< "$raw"
    for cpu in "${items[@]}"; do
        cpu=$((10#$cpu))
        [ "$cpu" -ne 0 ] || die "refusing to offline cpu0"
        [ "$cpu" -lt 4096 ] || die "cpu$cpu out of range"
        [ -f "$SYS_CPU/cpu$cpu/online" ] || die "cpu$cpu is not hotpluggable"
        out+=("$cpu")
    done
    printf '%s\n' "${out[@]}" | sort -un
}

count_online() {
    local n=0 f
    for f in "$SYS_CPU"/cpu[0-9]*/online; do
        [ "$(cat "$f" 2>/dev/null)" = "1" ] && n=$((n + 1))
    done
    # CPU0 has no 'online' file on kernels built without CPU0 hotplug.
    [ -f "$SYS_CPU/cpu0/online" ] || n=$((n + 1))
    echo "$n"
}

# set_online <0|1> <cpu>... — prints the number of CPUs that did not take.
set_online() {
    local val="$1" cpu failed=0
    shift
    for cpu in "$@"; do
        echo "$val" > "$SYS_CPU/cpu$cpu/online" 2>/dev/null
        [ "$(cat "$SYS_CPU/cpu$cpu/online" 2>/dev/null)" = "$val" ] || failed=$((failed + 1))
    done
    echo "$failed"
}

case "${1:-}" in
    park)
        [ $# -eq 2 ] || die "usage: park <cpu-list>"
        cpus_raw=$(parse_cpus "$2") || exit 1
        mapfile -t cpus <<< "$cpus_raw"
        remaining=$(( $(count_online) - ${#cpus[@]} ))
        [ "$remaining" -ge 2 ] || die "refusing to park: would leave only $remaining cpus online"
        failed=$(set_online 0 "${cpus[@]}")
        [ "$failed" -eq 0 ] || die "could not park $failed cpu(s)"
        echo "DONE_PARK"
        ;;

    unpark)
        [ $# -eq 2 ] || die "usage: unpark <cpu-list>"
        cpus_raw=$(parse_cpus "$2") || exit 1
        mapfile -t cpus <<< "$cpus_raw"
        failed=$(set_online 1 "${cpus[@]}")
        [ "$failed" -eq 0 ] || die "could not unpark $failed cpu(s)"
        echo "DONE_UNPARK"
        ;;

    unpark-all)
        # Safe without topology knowledge: bring every hotpluggable CPU back up.
        failed=0
        for f in "$SYS_CPU"/cpu[0-9]*/online; do
            echo 1 > "$f" 2>/dev/null
            [ "$(cat "$f" 2>/dev/null)" = "1" ] || failed=$((failed + 1))
        done
        [ "$failed" -eq 0 ] || die "could not unpark $failed cpu(s)"
        echo "DONE_UNPARK"
        ;;

    governor)
        for gov in "$SYS_CPU"/cpu[0-9]*/cpufreq/scaling_governor; do
            echo powersave > "$gov" 2>/dev/null
        done
        for epp in "$SYS_CPU"/cpu[0-9]*/cpufreq/energy_performance_preference; do
            echo power > "$epp" 2>/dev/null
        done
        echo "DONE_GOVERNOR"
        ;;

    set-governor)
        # Used by the benchmark to force `performance` while measuring, then put
        # the old governor back. Validate against what the kernel actually
        # offers so we can only ever write a real governor name.
        [ $# -eq 2 ] || die "usage: set-governor <name>"
        want="$2"
        avail=$(cat "$SYS_CPU/cpu0/cpufreq/scaling_available_governors" 2>/dev/null)
        case " $avail " in
            *" $want "*) ;;
            *) die "unknown governor '$want' (available: $avail)" ;;
        esac
        for gov in "$SYS_CPU"/cpu[0-9]*/cpufreq/scaling_governor; do
            echo "$want" > "$gov" 2>/dev/null
        done
        echo "DONE_SETGOVERNOR"
        ;;

    audio)
        echo 1 > /sys/module/snd_hda_intel/parameters/power_save 2>/dev/null \
            || die "audio power_save not available"
        echo "DONE_AUDIO"
        ;;

    sata)
        found=0
        for dev in /sys/class/scsi_host/host*/link_power_management_policy; do
            [ -f "$dev" ] || continue
            echo med_power_with_dipm > "$dev" 2>/dev/null && found=1
        done
        [ "$found" -eq 1 ] || die "no SATA hosts found"
        echo "DONE_SATA"
        ;;

    *)
        echo "Usage: gaming-ccd-helper park <cpus> | unpark <cpus> | unpark-all |"
        echo "       governor | set-governor <name> | audio | sata"
        echo "(persistent /etc changes live in gaming-cc-etc-helper)"
        exit 1
        ;;
esac
