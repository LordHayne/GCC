#!/bin/bash
# gaming-ccd-helper — Root helper for CCD parking
# Called via pkexec from Gaming Command Center
# Usage: gaming-ccd-helper [on|off]
# on  = park CCD1 (disable cores)
# off = unpark CCD1 (re-enable cores)

CCD1_CPUS="6 7 8 9 10 11 18 19 20 21 22 23"

case "$1" in
  on)
    for cpu in $CCD1_CPUS; do
      echo 0 > /sys/devices/system/cpu/cpu$cpu/online 2>/dev/null
    done
    # Verify
    result=$(cat /sys/devices/system/cpu/cpu6/online 2>/dev/null)
    if [ "$result" = "0" ]; then
      echo "DONE_ON"
    else
      echo "FAIL_ON"
    fi
    ;;
  off)
    for cpu in $CCD1_CPUS; do
      echo 1 > /sys/devices/system/cpu/cpu$cpu/online 2>/dev/null
    done
    # Verify
    result=$(cat /sys/devices/system/cpu/cpu6/online 2>/dev/null)
    if [ "$result" = "1" ]; then
      echo "DONE_OFF"
    else
      echo "FAIL_OFF"
    fi
    ;;
  *)
    echo "Usage: gaming-ccd-helper [on|off]"
    exit 1
    ;;
esac