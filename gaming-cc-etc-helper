# gaming-cc-etc-helper — root helper for Gaming Command Center
#
# Usage:
#   gaming-cc-etc-helper modprobe     # NVreg_PreserveVideoMemoryAllocations=1
#   gaming-cc-etc-helper coolbits     # Option "Coolbits" "28"
#   gaming-cc-etc-helper maxmapcount  # vm.max_map_count = 2147483642
#
# Everything here writes to /etc and survives a reboot, so it sits behind its
# own polkit action that asks for admin authentication — unlike core parking,
# which is a revertible runtime change and stays password-free.
#
# These files belong to the user, not to us. The previous version truncated
# them with `>`, silently destroying any NVIDIA options they had already set.
# So: back up first, then merge the one setting we care about and leave the
# rest of the file alone.

set -u

NVIDIA_CONF=/etc/modprobe.d/nvidia.conf
XORG_DIR=/etc/X11/xorg.conf.d
XORG_CONF=$XORG_DIR/10-nvidia.conf
SYSCTL_CONF=/etc/sysctl.d/99-gaming-cc.conf
MAX_MAP_COUNT=2147483642
AUDIO_CONF=/etc/modprobe.d/gaming-cc-audio.conf
SATA_RULE=/etc/udev/rules.d/99-gaming-cc-sata.rules
GOVERNOR_UNIT=/etc/systemd/system/gaming-cc-governor.service

die() { echo "ERR: $1" >&2; exit 1; }

# Keep a timestamped copy of a file we are about to change.
backup() {
    local f="$1"
    [ -e "$f" ] || return 0
    local b="$f.gcc-backup-$(date +%Y%m%d-%H%M%S)"
    cp -a "$f" "$b" || die "could not back up $f"
    echo "NOTE: backed up $f -> $b"
}

case "${1:-}" in
    modprobe)
        opt="NVreg_PreserveVideoMemoryAllocations=1"

        if [ ! -e "$NVIDIA_CONF" ]; then
            mkdir -p "$(dirname "$NVIDIA_CONF")" || die "could not create /etc/modprobe.d"
            printf '# Written by Gaming Command Center\noptions nvidia %s\n' "$opt" \
                > "$NVIDIA_CONF" || die "could not write $NVIDIA_CONF"
            echo "DONE_MODPROBE"
            exit 0
        fi

        # Both spellings occur in the wild:
        #   options nvidia NVreg_PreserveVideoMemoryAllocations=1
        #   options nvidia "NVreg_PreserveVideoMemoryAllocations=1"
        if grep -qE 'NVreg_PreserveVideoMemoryAllocations="?1"?([[:space:]]|$)' "$NVIDIA_CONF"; then
            echo "NOTE: already set, file left untouched"
            echo "DONE_MODPROBE"
            exit 0
        fi

        backup "$NVIDIA_CONF"

        if grep -qE 'NVreg_PreserveVideoMemoryAllocations=' "$NVIDIA_CONF"; then
            # Set to something other than 1 — correct the digit, keep the quoting.
            sed -i -E 's/(NVreg_PreserveVideoMemoryAllocations="?)[0-9]+/\11/g' \
                "$NVIDIA_CONF" || die "could not update $NVIDIA_CONF"
        else
            # modprobe.d concatenates several `options nvidia` lines for the same
            # module, so appending our own leaves the existing ones intact.
            printf '\n# Added by Gaming Command Center\noptions nvidia %s\n' "$opt" \
                >> "$NVIDIA_CONF" || die "could not append to $NVIDIA_CONF"
        fi
        echo "DONE_MODPROBE"
        ;;

    coolbits)
        mkdir -p "$XORG_DIR" || die "could not create $XORG_DIR"

        if [ ! -e "$XORG_CONF" ]; then
            cat > "$XORG_CONF" << 'EOF' || die "could not write $XORG_CONF"
# Written by Gaming Command Center
Section "Device"
    Identifier "NVIDIA"
    Driver "nvidia"
    Option "Coolbits" "28"
EndSection
EOF
            echo "DONE_COOLBITS"
            exit 0
        fi

        if grep -qEi '^[[:space:]]*Option[[:space:]]+"Coolbits"[[:space:]]+"28"' "$XORG_CONF"; then
            echo "NOTE: already set, file left untouched"
            echo "DONE_COOLBITS"
            exit 0
        fi

        backup "$XORG_CONF"

        if grep -qEi '^[[:space:]]*Option[[:space:]]+"Coolbits"' "$XORG_CONF"; then
            # Wrong Coolbits value — fix it without touching anything else.
            sed -i -E 's/^([[:space:]]*)Option[[:space:]]+"[Cc]oolbits"[[:space:]]+"[0-9]+"/\1Option "Coolbits" "28"/' \
                "$XORG_CONF" || die "could not update $XORG_CONF"
        elif grep -qEi '^[[:space:]]*Section[[:space:]]+"Device"' "$XORG_CONF"; then
            # The user already has a Device section — add the option inside it.
            # A second Device section for the same GPU would make Xorg complain.
            awk '
                { print }
                !done && /^[[:space:]]*Section[[:space:]]+"Device"/ {
                    print "    Option \"Coolbits\" \"28\"   # Gaming Command Center"
                    done = 1
                }
            ' "$XORG_CONF" > "$XORG_CONF.gcc-tmp" \
                && mv "$XORG_CONF.gcc-tmp" "$XORG_CONF" \
                || die "could not update $XORG_CONF"
        else
            # File exists but has no Device section — ours can stand on its own.
            cat >> "$XORG_CONF" << 'EOF' || die "could not append to $XORG_CONF"

# Added by Gaming Command Center
Section "Device"
    Identifier "NVIDIA"
    Driver "nvidia"
    Option "Coolbits" "28"
EndSection
EOF
        fi
        echo "DONE_COOLBITS"
        ;;

    maxmapcount)
        # Persist for next boot AND apply now, so the fix takes effect without a
        # reboot. Our own file in sysctl.d, so a plain rewrite is safe here.
        mkdir -p "$(dirname "$SYSCTL_CONF")" || die "could not create /etc/sysctl.d"
        printf '# Written by Gaming Command Center\nvm.max_map_count = %s\n' \
            "$MAX_MAP_COUNT" > "$SYSCTL_CONF" || die "could not write $SYSCTL_CONF"
        # Apply to the running kernel; report if that step fails but the file is set.
        if ! sysctl -q -w "vm.max_map_count=$MAX_MAP_COUNT" 2>/dev/null; then
            echo "$MAX_MAP_COUNT" > /proc/sys/vm/max_map_count \
                || echo "NOTE: written to $SYSCTL_CONF, takes effect on next boot"
        fi
        echo "DONE_MAXMAPCOUNT"
        ;;

    audiopersist)
        # Persist snd_hda_intel power_save across reboots via modprobe.d, and
        # apply it to the already-loaded module now (no reboot needed). Our own
        # file, so a plain rewrite is safe.
        mkdir -p "$(dirname "$AUDIO_CONF")" || die "could not create /etc/modprobe.d"
        printf '# Written by Gaming Command Center\noptions snd_hda_intel power_save=1\n' \
            > "$AUDIO_CONF" || die "could not write $AUDIO_CONF"
        echo 1 > /sys/module/snd_hda_intel/parameters/power_save 2>/dev/null \
            || echo "NOTE: written to $AUDIO_CONF, takes effect on next boot"
        echo "DONE_AUDIO"
        ;;

    satapersist)
        # SATA link power isn't a module param and sysfs isn't kept by sysctl,
        # so persist it with a udev rule that re-applies on every boot/hotplug,
        # and set it on the current hosts now.
        mkdir -p "$(dirname "$SATA_RULE")" || die "could not create /etc/udev/rules.d"
        printf '# Written by Gaming Command Center\nACTION=="add", SUBSYSTEM=="scsi_host", KERNEL=="host*", ATTR{link_power_management_policy}="med_power_with_dipm"\n' \
            > "$SATA_RULE" || die "could not write $SATA_RULE"
        for dev in /sys/class/scsi_host/host*/link_power_management_policy; do
            [ -w "$dev" ] && echo med_power_with_dipm > "$dev" 2>/dev/null || true
        done
        echo "DONE_SATA"
        ;;

    governorpersist)
        # Persist a resting CPU governor via a tiny systemd oneshot that sets it
        # on every boot; Game Mode and the benchmark still change it at runtime.
        # Applied now too. Defaults to powersave (what System Doctor recommends).
        GOV="${2:-powersave}"
        avail=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_available_governors 2>/dev/null)
        case " $avail " in
            *" $GOV "*) : ;;
            *) die "governor '$GOV' not available (have:$avail)" ;;
        esac
        cat > "$GOVERNOR_UNIT" <<UNITEOF || die "could not write $GOVERNOR_UNIT"
[Unit]
Description=Gaming Command Center — default CPU governor ($GOV)
After=multi-user.target
[Service]
Type=oneshot
ExecStart=/bin/sh -c 'for g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do echo $GOV > "\$g" 2>/dev/null || true; done'
[Install]
WantedBy=multi-user.target
UNITEOF
        systemctl daemon-reload 2>/dev/null || true
        systemctl enable gaming-cc-governor.service >/dev/null 2>&1 || true
        for g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
            echo "$GOV" > "$g" 2>/dev/null || true
        done
        echo "DONE_GOVERNOR"
        ;;

    *)
        echo "Usage: gaming-cc-etc-helper modprobe | coolbits | maxmapcount | audiopersist | satapersist | governorpersist"
        exit 1
        ;;
esac
